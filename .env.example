# ─────────────────────────────────────────────────────────────────────────────
# FirstRung environment configuration. Everything here is OPTIONAL.
#
# With nothing set, FirstRung runs as an anonymous matcher using key-less job
# sources (The Muse, Remotive, Arbeitnow) and shows the top-3 email as an in-page
# preview. Add keys to upgrade each part. Copy to `.env.local` to use.
# ─────────────────────────────────────────────────────────────────────────────

NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── On-the-ground TANZANIA jobs via JSearch (free, RECOMMENDED for this app) ──
# Aggregates Google for Jobs with a real country filter (country=tz), so it pulls
# Tanzanian boards and company career pages. Without it, only remote jobs (open to
# Tanzania) show. Get a free key at https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
RAPIDAPI_KEY=""

# ── Semantic matching via Groq (free tier). Server-only, never exposed. ──
# When set, matches are reranked by a fast LLM that understands meaning and
# synonyms across English and Swahili. Falls back to transparent lexical ranking
# if unset or unavailable. Get a free key at https://console.groq.com/keys
# NOTE: this sends the search profile (no name/email) + short public job snippets
# to Groq, a third party. Leave blank to keep matching fully local.
GROQ_API_KEY=""

# ── Precise city / country job search (free; note: no Tanzania market) ──
# Register a free app at https://developer.adzuna.com/ and paste the two values.
# Without these, on-site location still works for major cities via The Muse,
# but Adzuna gives the best coverage (especially the UK).
ADZUNA_APP_ID=""
ADZUNA_APP_KEY=""
ADZUNA_COUNTRY="gb"

# ── Real email sending (free). Pick ONE. Without either, email runs in preview. ──
# Brevo: https://www.brevo.com  free 300/day, can email anyone from a verified
# sender, no domain required. Easiest.
BREVO_API_KEY=""
# Resend: https://resend.com  free 3k/mo, but needs a domain you verify to email
# arbitrary recipients.
RESEND_API_KEY=""
# The from-address shown on the email. For Brevo it must be a verified sender.
EMAIL_FROM="onboarding@yourdomain.dev"
EMAIL_FROM_NAME="FirstRung"

# Signs the email confirmation links (double opt-in). REQUIRED in production when
# email is enabled. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
TOKEN_SECRET=""
